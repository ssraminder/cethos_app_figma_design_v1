# Copy this file to .env (or .env.local) and fill in real values.
# Never commit .env files. The publishable anon key in older commits was
# rotated after the May 2026 security advisory — request a fresh key from
# the Supabase dashboard.

# Builder.io key — used at runtime for visual editing.
# https://www.builder.io/c/docs/using-your-api-key
VITE_PUBLIC_BUILDER_KEY=

# Toggle/diagnostic string used by the server's /api/ping route.
PING_MESSAGE="ping pong"

# Supabase — Cethos_Translation_App project
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=

# Service-role key — server-side only. Never expose to the client.
# Read by edge functions and any node script that needs to bypass RLS
# (e.g. server/scripts/rls-audit.ts).
SUPABASE_SERVICE_ROLE_KEY=
